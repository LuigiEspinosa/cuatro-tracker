# PostgreSQL
DATABASE_URL="postgresql://tracker:password@localhost:5432/tracker"
DB_PASS="your-postgres-password"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudflare API Token
CLOUDFLARE_API_TOKEN=""

# Auth
NEXTAUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_PASS="your-admin-password"

# TMDB - themoviedb.org/settings/api
TMDB_API_KEY=""

# IGDB (Twitch app) - dev.twitch.tv/console
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# Steam = steamcommunity.com/dev/apikey
STEAM_API_KEY=""
STEAM_USER_ID=""

# qBittorrent (internal Docker network = do not expose externally)
QBITTORRENT_HOST="http://qbittorrent:8080"
QBITTORRENT_USER="admin"
QBITTORRENT_PASS=""

# Host path for qBittorrent downloads volume
DOWNLOAD_PATH="/your/download/path"

# Logging - one of: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Sentry - optional. Leave blank to disable error tracking.
# Provision a Sentry project (or self-host GlitchTip) to get the DSN.
SENTRY_DSN=""

# Same Sentry DSN, exposed to the client bundle.
# NEXT_PUBLIC_ vars are baked at build time; restart the stack after changing.
NEXT_PUBLIC_SENTRY_DSN=""

# Umami analytics website-id - optional. Leave blank to disable client analytics.
# Add tracker.cuatro.dev to the existing Umami instance, copy the website-id here.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
