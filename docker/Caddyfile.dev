# Development-only Caddyfile.
# No domain, no TLS, no ACME challenges.
# Use when running the full Docker stack locally to test without a real cert.
# Access at http://localhost

http://localhost {
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
  reverse_proxy app:3000
}
